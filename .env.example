# Local Postgres role with access to the bike_epos database.
# On many macOS setups this is your local username, for example:
# DATABASE_URL=postgresql://thomaswitherspoon@localhost:5432/bike_epos
DATABASE_URL=postgresql://YOUR_LOCAL_PG_ROLE@localhost:5432/bike_epos
AUTH_JWT_SECRET=dev-secret
PORT=3100
NODE_ENV=development
COOKIE_SECRET=dev-cookie-secret
# Optional for controlled one-time production bootstrap only:
# ALLOW_INITIAL_ADMIN_BOOTSTRAP=1
# Optional local non-test header auth bypass. When enabled outside NODE_ENV=test,
# you must also set INTERNAL_AUTH_SHARED_SECRET.
# ALLOW_HEADER_AUTH=1
# INTERNAL_AUTH_SHARED_SECRET=replace-me
# Optional workshop notification delivery settings.
# EMAIL_DELIVERY_MODE=log
# SMTP_URL=smtps://username:password@mail.example.com:465
# EMAIL_FROM=hello@example.com
# EMAIL_FROM_NAME=CorePOS
# WORKSHOP_NOTIFICATION_EMAIL_ENABLED=1
# SMS_DELIVERY_MODE=log
# SMS_FROM=CorePOS
# WORKSHOP_NOTIFICATION_SMS_ENABLED=1
# WHATSAPP_DELIVERY_MODE=log
# WHATSAPP_FROM=whatsapp:+14155238886
# WORKSHOP_NOTIFICATION_WHATSAPP_ENABLED=1
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# PUBLIC_APP_URL=http://localhost:3100
# Optional web-order shipping-label print-agent delivery from CorePOS:
# COREPOS_SHIPPING_PRINT_AGENT_URL=http://127.0.0.1:3211
# COREPOS_SHIPPING_PRINT_AGENT_TIMEOUT_MS=7000
# COREPOS_SHIPPING_PRINT_AGENT_SHARED_SECRET=replace-me
# Optional Windows-local print agent settings when running `npm run print-agent:start`:
# COREPOS_PRINT_AGENT_BIND_HOST=127.0.0.1
# COREPOS_PRINT_AGENT_PORT=3211
# COREPOS_PRINT_AGENT_TRANSPORT=DRY_RUN
# COREPOS_PRINT_AGENT_DEFAULT_PRINTER_NAME=Dispatch Zebra GK420d
# COREPOS_PRINT_AGENT_RAW_TCP_HOST=192.168.1.50
# COREPOS_PRINT_AGENT_RAW_TCP_PORT=9100
# COREPOS_PRINT_AGENT_RAW_TCP_TIMEOUT_MS=5000
# COREPOS_PRINT_AGENT_OUTPUT_DIR=tmp/print-agent-output
# COREPOS_PRINT_AGENT_SHARED_SECRET=replace-me
# OPS_LOGGING=1
# COREPOS_DEBUG=1
