TEST_DATABASE_URL=postgresql://bike_epos_test:bike_epos_test_pw@localhost:5433/bike_epos_test
TEST_BASE_URL=http://localhost:3100
AUTH_MODE=real
EMAIL_DELIVERY_MODE=log
SMS_DELIVERY_MODE=log
WHATSAPP_DELIVERY_MODE=log
# Optional channel gating for smart notification fallback tests:
# WORKSHOP_NOTIFICATION_EMAIL_ENABLED=1
# WORKSHOP_NOTIFICATION_SMS_ENABLED=1
# WORKSHOP_NOTIFICATION_WHATSAPP_ENABLED=1
# Header auth fallback is allowed automatically when NODE_ENV=test.
# For non-test local header bypass, set ALLOW_HEADER_AUTH=1.
# ALLOW_HEADER_AUTH=1
# Optional: extra protection when using header auth in shared environments.
# INTERNAL_AUTH_SHARED_SECRET=replace-me
