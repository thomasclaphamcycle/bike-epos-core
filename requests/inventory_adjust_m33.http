@baseUrl = http://localhost:3100
@managerRole = MANAGER
@staffId = demo-staff
@variantId = REPLACE_VARIANT_ID

### Inventory adjust page (MANAGER+)
GET {{baseUrl}}/inventory/adjust
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{staffId}}

### Post positive adjustment (MANAGER+)
POST {{baseUrl}}/api/inventory/adjustments
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{staffId}}

{
  "variantId": "{{variantId}}",
  "quantityDelta": 5,
  "reason": "COUNT_CORRECTION",
  "note": "Cycle count correction"
}

### Post positive adjustment at a location (MANAGER+)
POST {{baseUrl}}/api/inventory/adjustments
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{staffId}}

{
  "variantId": "{{variantId}}",
  "locationId": "{{locationId}}",
  "quantityDelta": 3,
  "reason": "COUNT_CORRECTION",
  "note": "Workshop bin count correction"
}

### Post negative adjustment (MANAGER+)
POST {{baseUrl}}/api/inventory/adjustments
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{staffId}}

{
  "variantId": "{{variantId}}",
  "quantityDelta": -2,
  "reason": "DAMAGED",
  "note": "Damaged in transit"
}

### Check on-hand after adjustments
GET {{baseUrl}}/api/inventory/on-hand?variantId={{variantId}}
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}

### Check on-hand at a specific location
GET {{baseUrl}}/api/inventory/on-hand?variantId={{variantId}}&locationId={{locationId}}
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}
