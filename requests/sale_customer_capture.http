@baseUrl = http://localhost:3100
@staffRole = STAFF
@staffId = sale-customer-capture-request
@saleId = REPLACE_SALE_ID
@basketId = REPLACE_BASKET_ID
@token = REPLACE_CAPTURE_TOKEN
@station = till-pc

### Create sale-linked customer capture session (STAFF+)
POST {{baseUrl}}/api/sales/{{saleId}}/customer-capture-sessions
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}
Content-Type: application/json

{
  "stationKey": "TILL_PC"
}

### Get latest staff-visible customer capture session for a sale
GET {{baseUrl}}/api/sales/{{saleId}}/customer-capture-sessions/current
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}

### Create basket-linked customer capture session (STAFF+)
POST {{baseUrl}}/api/baskets/{{basketId}}/customer-capture-sessions
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}
Content-Type: application/json

{
  "stationKey": "TILL_PC"
}

### Get latest staff-visible customer capture session for a basket
GET {{baseUrl}}/api/baskets/{{basketId}}/customer-capture-sessions/current
X-Staff-Role: {{staffRole}}
X-Staff-Id: {{staffId}}

### Get public customer capture session state
GET {{baseUrl}}/api/public/customer-capture/{{token}}

### Resolve the current live customer capture session for a static NFC tap point
GET {{baseUrl}}/api/public/customer-capture/entry/{{station}}

### Preview whether the public capture details will match an existing customer
POST {{baseUrl}}/api/public/customer-capture/{{token}}/preview
Content-Type: application/json

{
  "email": "jamie.rider@example.com",
  "phone": "07123456789"
}

### Submit public customer capture details
POST {{baseUrl}}/api/public/customer-capture/{{token}}
Content-Type: application/json

{
  "firstName": "Jamie",
  "lastName": "Rider",
  "email": "jamie.rider@example.com",
  "phone": "07123456789",
  "emailMarketingConsent": true,
  "smsMarketingConsent": false
}
