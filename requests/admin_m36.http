@baseUrl = http://localhost:3000

### List users (ADMIN)
GET {{baseUrl}}/api/admin/users

### Staff directory (MANAGER+)
GET {{baseUrl}}/api/staff-directory

### Create user (ADMIN)
POST {{baseUrl}}/api/admin/users
Content-Type: application/json

{
  "name": "Store Staff",
  "email": "staff@example.com",
  "role": "STAFF",
  "tempPassword": "TempPass123!"
}

### Update user (ADMIN)
PATCH {{baseUrl}}/api/admin/users/{{userId}}
Content-Type: application/json

{
  "name": "Store Staff Updated",
  "role": "MANAGER",
  "isActive": true
}

### Reset user password (ADMIN)
POST {{baseUrl}}/api/admin/users/{{userId}}/reset-password
Content-Type: application/json

{
  "tempPassword": "AnotherTempPass123!"
}

### Update operational role tag (MANAGER+)
PATCH {{baseUrl}}/api/staff-directory/{{userId}}/operational-role
Content-Type: application/json

{
  "operationalRole": "WORKSHOP"
}

### Update workshop staffing profile (MANAGER+)
PATCH {{baseUrl}}/api/staff-directory/{{userId}}/profile
Content-Type: application/json

{
  "operationalRole": "WORKSHOP",
  "isTechnician": true
}

### Audit feed (MANAGER+)
GET {{baseUrl}}/api/audit?entityType=USER&limit=50
