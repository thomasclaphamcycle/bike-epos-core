@baseUrl = http://localhost:3100
@printerId = 00000000-0000-4000-8000-000000000000
@shippingProviderKey = GENERIC_HTTP_ZPL
@easyPostProviderKey = EASYPOST

### Get persisted shop settings (MANAGER+)
GET {{baseUrl}}/api/settings
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Get public app config (STAFF+)
GET {{baseUrl}}/api/config
X-Staff-Role: STAFF
X-Staff-Id: demo-staff

### Update POS Settings (ADMIN)
PATCH {{baseUrl}}/api/settings
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "pos": {
    "defaultTaxRatePercent": 20,
    "barcodeSearchAutoFocus": true,
    "defaultSaleType": "RETAIL",
    "defaultCustomerType": "WALK_IN",
    "newBasketMode": "RETAIL_WALK_IN",
    "requireCustomerBeforeCheckout": false,
    "allowZeroPriceLines": false,
    "allowNegativeDiscounts": false,
    "managerApprovalForDiscounts": true,
    "managerApprovalForRefunds": true,
    "managerApprovalForVoids": true,
    "autoClearBasketAfterSale": true,
    "holdBasketTtlHours": 24,
    "quoteExpiryDays": 30,
    "requireLineNotes": false,
    "scanQuantityMode": "INCREMENT_ONE",
    "quickAddEnabled": true,
    "quickAddProducts": [
      { "label": "Inner Tube", "query": "Inner Tube" },
      { "label": "Chain Lube", "query": "Chain Lube" },
      { "label": "Brake Pads", "query": "Brake Pads" }
    ],
    "duplicateScanBehavior": "INCREMENT_QUANTITY",
    "enabledTenderMethods": ["CARD", "CASH", "STORE_CREDIT"],
    "splitPaymentsEnabled": true,
    "cashRoundingMode": "NONE",
    "promptForReceiptAfterPayment": true,
    "requirePinForCheckout": false,
    "requireManagerOverrideForRestrictedActions": true,
    "tillLockTimeoutSeconds": 300,
    "compactBasketView": false,
    "showKeyboardShortcutHints": true
  }
}

### Get Store Info (ADMIN)
GET {{baseUrl}}/api/settings/store-info
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

### List shipping providers (MANAGER+)
GET {{baseUrl}}/api/settings/shipping-providers
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Update a configured shipping provider (ADMIN)
PUT {{baseUrl}}/api/settings/shipping-providers/{{shippingProviderKey}}
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "enabled": true,
  "environment": "SANDBOX",
  "displayName": "Generic Courier Sandbox",
  "endpointBaseUrl": "http://127.0.0.1:4110",
  "accountId": "sandbox-account-1",
  "apiKey": "replace-with-provider-sandbox-key"
}

### Update EasyPost shipping provider settings (ADMIN)
PUT {{baseUrl}}/api/settings/shipping-providers/{{easyPostProviderKey}}
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "enabled": true,
  "environment": "SANDBOX",
  "displayName": "EasyPost Sandbox",
  "carrierAccountId": "ca_replace_me",
  "defaultServiceCode": "GroundAdvantage",
  "defaultServiceName": "Ground Advantage",
  "parcelWeightOz": 24,
  "parcelLengthIn": 10,
  "parcelWidthIn": 8,
  "parcelHeightIn": 4,
  "webhookSecret": "replace-with-easypost-webhook-secret",
  "apiKey": "EZTK_replace_me"
}

### Set the default shipping provider (ADMIN)
PUT {{baseUrl}}/api/settings/shipping-providers/default
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "providerKey": "{{shippingProviderKey}}"
}

### List registered dispatch printers (MANAGER+)
GET {{baseUrl}}/api/settings/printers
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Get persisted shipping print helper settings (MANAGER+)
GET {{baseUrl}}/api/settings/shipping-print-agent
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Get persisted bike-tag print helper settings (MANAGER+)
GET {{baseUrl}}/api/settings/bike-tag-print-agent
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Get persisted receipt print helper settings (MANAGER+)
GET {{baseUrl}}/api/settings/receipt-print-agent
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Update persisted receipt print helper settings (ADMIN)
PUT {{baseUrl}}/api/settings/receipt-print-agent
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "url": "http://192.168.1.45:3214",
  "sharedSecret": "replace-with-shared-secret"
}

### Get receipt workstation defaults (MANAGER+)
GET {{baseUrl}}/api/settings/receipt-workstations
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Update receipt workstation defaults (ADMIN)
PUT {{baseUrl}}/api/settings/receipt-workstations
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "workstations": [
    {
      "key": "TILL_PC",
      "defaultPrinterId": "{{printerId}}"
    },
    {
      "key": "WORKSHOP_1",
      "defaultPrinterId": "{{printerId}}"
    },
    {
      "key": "WORKSHOP_2",
      "defaultPrinterId": null
    }
  ]
}

