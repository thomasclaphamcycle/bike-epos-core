@baseUrl = http://localhost:3100
@printerId = 00000000-0000-4000-8000-000000000000
@shippingProviderKey = GENERIC_HTTP_ZPL

### Get persisted shop settings (MANAGER+)
GET {{baseUrl}}/api/settings
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Get public app config (STAFF+)
GET {{baseUrl}}/api/config
X-Staff-Role: STAFF
X-Staff-Id: demo-staff

### Get Store Info (ADMIN)
GET {{baseUrl}}/api/settings/store-info
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

### List shipping providers (MANAGER+)
GET {{baseUrl}}/api/settings/shipping-providers
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Update a configured shipping provider (ADMIN)
PUT {{baseUrl}}/api/settings/shipping-providers/{{shippingProviderKey}}
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "enabled": true,
  "environment": "SANDBOX",
  "displayName": "Generic Courier Sandbox",
  "endpointBaseUrl": "http://127.0.0.1:4110",
  "accountId": "sandbox-account-1",
  "apiKey": "replace-with-provider-sandbox-key"
}

### Set the default shipping provider (ADMIN)
PUT {{baseUrl}}/api/settings/shipping-providers/default
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "providerKey": "{{shippingProviderKey}}"
}

### List registered dispatch printers (MANAGER+)
GET {{baseUrl}}/api/settings/printers
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

### Create a registered dispatch printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Dispatch Zebra GK420d",
  "key": "DISPATCH_ZEBRA_GK420D",
  "transportMode": "DRY_RUN",
  "location": "Dispatch bench",
  "notes": "Primary shipping-label printer",
  "setAsDefaultShippingLabel": true
}

### Update a registered dispatch printer (ADMIN)
PATCH {{baseUrl}}/api/settings/printers/{{printerId}}
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "transportMode": "RAW_TCP",
  "rawTcpHost": "192.168.1.50",
  "rawTcpPort": 9100,
  "location": "Packing bench"
}

### Set the default shipping-label printer (ADMIN)
PUT {{baseUrl}}/api/settings/printers/default-shipping-label
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "printerId": "{{printerId}}"
}

### Update persisted shop settings (MANAGER+)
PATCH {{baseUrl}}/api/settings
Content-Type: application/json
X-Staff-Role: MANAGER
X-Staff-Id: demo-manager

{
  "store": {
    "name": "CorePOS Cycles",
    "businessName": "CorePOS Cycles Ltd",
    "email": "hello@corepos.local",
    "phone": "01234 567890",
    "website": "https://www.corepos.local",
    "addressLine1": "123 Service Lane",
    "addressLine2": "Unit 4",
    "city": "Clapham",
    "region": "Greater London",
    "postcode": "SW4 0HY",
    "country": "United Kingdom",
    "openingHours": {
      "MONDAY": { "isClosed": false, "opensAt": "10:00", "closesAt": "18:30" },
      "TUESDAY": { "isClosed": false, "opensAt": "10:00", "closesAt": "18:30" },
      "WEDNESDAY": { "isClosed": false, "opensAt": "10:00", "closesAt": "18:30" },
      "THURSDAY": { "isClosed": false, "opensAt": "10:00", "closesAt": "18:30" },
      "FRIDAY": { "isClosed": false, "opensAt": "10:00", "closesAt": "18:30" },
      "SATURDAY": { "isClosed": false, "opensAt": "09:00", "closesAt": "16:30" },
      "SUNDAY": { "isClosed": true, "opensAt": "", "closesAt": "" }
    },
    "vatNumber": "GB123456789",
    "companyNumber": "01234567",
    "defaultCurrency": "GBP",
    "timeZone": "Europe/London",
    "logoUrl": "https://cdn.corepos.local/logo.png",
    "footerText": "Thanks for riding with CorePOS."
  },
  "pos": {
    "defaultTaxRatePercent": 20,
    "barcodeSearchAutoFocus": true
  },
  "workshop": {
    "defaultJobDurationMinutes": 90,
    "defaultDepositPence": 1500,
    "maxBookingsPerDay": 10,
    "manageTokenTtlDays": 45,
    "requestTimingMessage": "Choose a preferred workshop date and the shop will confirm the final timing."
  },
  "notifications": {
    "workshopAutoSendEnabled": true,
    "workshopEmailEnabled": true,
    "workshopSmsEnabled": false,
    "workshopWhatsappEnabled": true
  },
  "operations": {
    "lowStockThreshold": 5,
    "dashboardWeatherEnabled": true
  }
}

