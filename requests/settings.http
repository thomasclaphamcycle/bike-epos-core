### Create a registered dispatch printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Dispatch Zebra GK420d",
  "key": "DISPATCH_ZEBRA_GK420D",
  "transportMode": "DRY_RUN",
  "location": "Dispatch bench",
  "notes": "Primary shipping-label printer",
  "setAsDefaultShippingLabel": true
}

### Create a registered USB Zebra helper printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Dispatch Zebra USB Helper",
  "key": "DISPATCH_ZEBRA_USB_HELPER",
  "transportMode": "WINDOWS_PRINTER",
  "windowsPrinterName": "ZDesigner GK420d",
  "location": "Dispatch bench",
  "notes": "USB Zebra running through the Windows helper host"
}

### Create a registered Dymo product-label printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Packing Bench Dymo",
  "key": "PACKING_BENCH_DYMO",
  "printerFamily": "DYMO_LABEL",
  "transportMode": "WINDOWS_PRINTER",
  "windowsPrinterName": "DYMO LabelWriter 550",
  "location": "Packing bench",
  "notes": "Primary product-label printer",
  "setAsDefaultProductLabel": true
}

### Create a registered office bike-tag printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Xerox VersaLink C405",
  "key": "XEROX_BIKE_TAG",
  "printerFamily": "OFFICE_DOCUMENT",
  "transportMode": "WINDOWS_PRINTER",
  "windowsPrinterName": "Xerox VersaLink C405",
  "location": "Back office",
  "notes": "Primary bike-tag office printer",
  "setAsDefaultBikeTag": true
}

### Create a registered thermal receipt printer (ADMIN)
POST {{baseUrl}}/api/settings/printers
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "name": "Till Receipt Printer",
  "key": "TILL_RECEIPT_PRINTER",
  "printerFamily": "THERMAL_RECEIPT",
  "transportMode": "RAW_TCP",
  "rawTcpHost": "192.168.1.60",
  "rawTcpPort": 9100,
  "location": "Main till",
  "notes": "Primary LAN receipt printer",
  "setAsDefaultReceipt": true
}

### Update a registered dispatch printer (ADMIN)
PATCH {{baseUrl}}/api/settings/printers/{{printerId}}
Content-Type: application/json
X-Staff-Role: ADMIN
X-Staff-Id: demo-admin

{
  "transportMode": "RAW_TCP",
  "rawTcpHost": "192.168.1.50",
  "rawTcpPort": 9100,
  "location": "Packing bench"
}

