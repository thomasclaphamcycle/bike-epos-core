@baseUrl = http://localhost:3000
@managerRole = MANAGER
@staffRole = STAFF

### Create supplier (MANAGER+)
POST {{baseUrl}}/api/suppliers
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "name": "Madison",
  "contactName": "Trade Desk",
  "email": "trade@madison.co.uk",
  "phone": "02071234567",
  "notes": "Main UK distributor"
}

### Search suppliers (STAFF+)
GET {{baseUrl}}/api/suppliers?query=mad
X-Staff-Role: {{staffRole}}

### Update supplier (MANAGER+)
PATCH {{baseUrl}}/api/suppliers/{{supplierId}}
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "contactName": "Procurement Team",
  "notes": "Prefers weekly orders"
}

### Create purchase order (MANAGER+)
POST {{baseUrl}}/api/purchase-orders
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "supplierId": "{{supplierId}}",
  "orderedAt": "2026-03-05T10:00:00.000Z",
  "expectedAt": "2026-03-12T10:00:00.000Z",
  "notes": "Weekly replenishment"
}

### Add/update purchase order items (MANAGER+)
POST {{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/items
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "lines": [
    {
      "variantId": "{{variantId}}",
      "quantityOrdered": 10,
      "unitCostPence": 2100
    }
  ]
}

### Get purchase order with items (STAFF+)
GET {{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}
X-Staff-Role: {{staffRole}}

### Receive partial line quantity (stock +, MANAGER+)
POST {{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/receive
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "locationId": "{{locationId}}",
  "lines": [
    {
      "purchaseOrderItemId": "{{purchaseOrderItemId}}",
      "quantity": 4
    }
  ]
}

### Receive remaining quantity -> status RECEIVED (MANAGER+)
POST {{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/receive
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "locationId": "{{locationId}}",
  "lines": [
    {
      "purchaseOrderItemId": "{{purchaseOrderItemId}}",
      "quantity": 6
    }
  ]
}

### Over-receive should fail with 409 (MANAGER+)
POST {{baseUrl}}/api/purchase-orders/{{purchaseOrderId}}/receive
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "locationId": "{{locationId}}",
  "lines": [
    {
      "purchaseOrderItemId": "{{purchaseOrderItemId}}",
      "quantity": 1
    }
  ]
}
