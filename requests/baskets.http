@baseUrl = http://localhost:3000
@staffRole = STAFF
@managerRole = MANAGER

### Create basket (STAFF+)
POST {{baseUrl}}/api/baskets
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{}

### Create basket with preloaded items (STAFF+)
POST {{baseUrl}}/api/baskets
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{
  "items": [
    {
      "variantId": "REPLACE_WITH_VARIANT_ID",
      "quantity": 2,
      "unitPricePence": 699
    }
  ]
}

### Get basket by id (STAFF+)
GET {{baseUrl}}/api/baskets/{{basketId}}
X-Staff-Role: {{staffRole}}

### Add by barcode (STAFF+)
POST {{baseUrl}}/api/baskets/{{basketId}}/items
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{
  "barcode": "1234567890123",
  "quantity": 1
}

### Add by variant id (STAFF+)
POST {{baseUrl}}/api/baskets/{{basketId}}/items
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{
  "variantId": "REPLACE_WITH_VARIANT_ID",
  "quantity": 2
}

### Update item quantity (STAFF+)
PATCH {{baseUrl}}/api/baskets/{{basketId}}/items/{{itemId}}
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{
  "quantity": 3
}

### Remove item (STAFF+)
DELETE {{baseUrl}}/api/baskets/{{basketId}}/items/{{itemId}}
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

### Checkout basket (optional payment, STAFF+)
POST {{baseUrl}}/api/baskets/{{basketId}}/checkout
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{}

### Checkout basket with CASH payment (STAFF+)
POST {{baseUrl}}/api/baskets/{{basketId}}/checkout
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{
  "paymentMethod": "CASH",
  "amountPence": 699
}

### Checkout basket again (idempotent: should return same sale)
POST {{baseUrl}}/api/baskets/{{basketId}}/checkout
Content-Type: application/json
X-Staff-Role: {{staffRole}}
X-Staff-Id: staff-1

{}

### Get sale by id (STAFF+)
GET {{baseUrl}}/api/sales/{{saleId}}
X-Staff-Role: {{staffRole}}

### List sales (STAFF+, optional date filters)
GET {{baseUrl}}/api/sales?from=2026-03-01&to=2026-03-31
X-Staff-Role: {{staffRole}}

### Return 1 unit from a sale item (MANAGER+)
POST {{baseUrl}}/api/sales/{{saleId}}/returns
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "items": [
    {
      "saleItemId": "{{saleItemId}}",
      "quantity": 1
    }
  ]
}

### Return 1 unit with refund (MANAGER+)
POST {{baseUrl}}/api/sales/{{saleId}}/returns
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "items": [
    {
      "saleItemId": "{{saleItemId}}",
      "quantity": 1
    }
  ],
  "refund": {
    "method": "CARD",
    "amountPence": 699,
    "providerRef": "refund-001"
  }
}

### Attempt to return more than sold quantity (expect 409)
POST {{baseUrl}}/api/sales/{{saleId}}/returns
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "items": [
    {
      "saleItemId": "{{saleItemId}}",
      "quantity": 999
    }
  ]
}

### Refund mismatch amount (expect 400 RETURN_PAYMENT_MISMATCH)
POST {{baseUrl}}/api/sales/{{saleId}}/returns
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: manager-1

{
  "items": [
    {
      "saleItemId": "{{saleItemId}}",
      "quantity": 1
    }
  ],
  "refund": {
    "method": "CASH",
    "amountPence": 1
  }
}
