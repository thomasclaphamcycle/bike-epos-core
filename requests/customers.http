@baseUrl = http://localhost:3100

### Create customer
POST {{baseUrl}}/api/customers
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "email": "jane.smith@example.com",
  "phone": "07123456789",
  "notes": "Workshop regular"
}

### Get customer by id
GET {{baseUrl}}/api/customers/{{customerId}}

### Customer domain-event timeline
GET {{baseUrl}}/api/events?entityType=CUSTOMER&entityId={{customerId}}

### Customer relationship timeline
GET {{baseUrl}}/api/customers/{{customerId}}/timeline

### Search customers by name/email/phone
GET {{baseUrl}}/api/customers?query=jane

### Update customer communication preferences
PATCH {{baseUrl}}/api/customers/{{customerId}}/communication-preferences
Content-Type: application/json

{
  "emailAllowed": true,
  "smsAllowed": false,
  "whatsappAllowed": true
}

### List reusable bike records for a customer
GET {{baseUrl}}/api/customers/{{customerId}}/bikes

### Create reusable bike record for a customer
POST {{baseUrl}}/api/customers/{{customerId}}/bikes
Content-Type: application/json

{
  "label": "Winter commuter",
  "make": "Genesis",
  "model": "Croix de Fer",
  "year": 2024,
  "bikeType": "ROAD",
  "colour": "Blue",
  "wheelSize": "700c",
  "frameSize": "54cm",
  "groupset": "Shimano 105",
  "motorBrand": null,
  "motorModel": null,
  "batterySerial": null,
  "frameNumber": "FRAME-12345",
  "serialNumber": "SER-12345",
  "registrationNumber": "REG-12345",
  "notes": "Rear rack fitted, customer prefers puncture-resistant tyres"
}

### Update reusable bike structured profile
PATCH {{baseUrl}}/api/customers/bikes/{{bikeId}}
Content-Type: application/json

{
  "year": 2025,
  "bikeType": "E_BIKE",
  "wheelSize": "29\"",
  "frameSize": "Large",
  "groupset": "Shimano XT",
  "motorBrand": "Bosch",
  "motorModel": "Performance Line CX",
  "batterySerial": "BAT-67890"
}

### Get reusable bike profile with metrics, completed history, open work, and finalized sale/receipt context
GET {{baseUrl}}/api/customers/bikes/{{bikeId}}

### Bike domain-event timeline
GET {{baseUrl}}/api/events?entityType=BIKE&entityId={{bikeId}}

### List bike service schedules
GET {{baseUrl}}/api/customers/bikes/{{bikeId}}/service-schedules?includeInactive=true

### Create bike service schedule
POST {{baseUrl}}/api/customers/bikes/{{bikeId}}/service-schedules
Content-Type: application/json

{
  "type": "GENERAL_SERVICE",
  "title": "General service",
  "description": "Main annual service cadence for this bike",
  "intervalMonths": 12,
  "lastServiceAt": "2026-03-01"
}

### Update bike service schedule
PATCH {{baseUrl}}/api/customers/bikes/{{bikeId}}/service-schedules/{{scheduleId}}
Content-Type: application/json

{
  "intervalMonths": 6,
  "nextDueAt": "2026-09-01",
  "isActive": true
}

### Mark bike service schedule serviced
POST {{baseUrl}}/api/customers/bikes/{{bikeId}}/service-schedules/{{scheduleId}}/mark-serviced
Content-Type: application/json

{
  "servicedAt": "2026-03-23",
  "servicedMileage": 3200
}

### Get workshop start defaults for a bike-led check-in
GET {{baseUrl}}/api/customers/bikes/{{bikeId}}/workshop-start

### Attach customer to sale
PATCH {{baseUrl}}/api/sales/{{saleId}}/customer
Content-Type: application/json

{
  "customerId": "{{customerId}}"
}

### Detach customer from sale
PATCH {{baseUrl}}/api/sales/{{saleId}}/customer
Content-Type: application/json

{
  "customerId": null
}

### Fetch sale (should include customer)
GET {{baseUrl}}/api/sales/{{saleId}}
