@baseUrl = http://localhost:3100
@managerRole = MANAGER
@managerId = online-store-demo-manager
@orderId = 00000000-0000-4000-8000-000000000000
@shipmentId = 00000000-0000-4000-8000-000000000000
@printerId = 00000000-0000-4000-8000-000000000000

### List web orders (MANAGER+)
GET {{baseUrl}}/api/online-store/orders?take=20&skip=0
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Create a web order for dispatch testing (MANAGER+)
POST {{baseUrl}}/api/online-store/orders
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

{
  "orderNumber": "WEB-MANUAL-1001",
  "sourceChannel": "INTERNAL_MOCK_WEB_STORE",
  "externalOrderRef": "checkout-session-1001",
  "customerName": "Jamie Dispatch",
  "customerEmail": "jamie.dispatch@example.com",
  "customerPhone": "07123 456789",
  "shippingRecipientName": "Jamie Dispatch",
  "shippingAddressLine1": "7 Dispatch Lane",
  "shippingCity": "Clapham",
  "shippingRegion": "London",
  "shippingPostcode": "SW4 0HY",
  "shippingCountry": "United Kingdom",
  "shippingPricePence": 495,
  "items": [
    {
      "sku": "WEB-LABEL-DEMO-1",
      "productName": "Dispatch Test Product",
      "variantName": "Standard",
      "quantity": 1,
      "unitPricePence": 2499
    }
  ]
}

### Get one web order with shipment state (MANAGER+)
GET {{baseUrl}}/api/online-store/orders/{{orderId}}
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Generate a shipment label for a web order (MANAGER+)
POST {{baseUrl}}/api/online-store/orders/{{orderId}}/shipments
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

{
  "providerKey": "GENERIC_HTTP_ZPL",
  "serviceCode": "NEXT_DAY",
  "serviceName": "Next Day Dispatch"
}

### Generate an EasyPost-backed shipment label using configured defaults (MANAGER+)
POST {{baseUrl}}/api/online-store/orders/{{orderId}}/shipments
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

{
  "providerKey": "EASYPOST"
}

### Get stored shipment label payload (MANAGER+)
GET {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/label
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Get raw label content for local print-agent testing (MANAGER+)
GET {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/label/content
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Refresh shipment/provider state from the configured provider (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/refresh
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Receive an EasyPost provider webhook (unsigned placeholder example)
### Replace the HMAC headers with a real signature generated from:
###   x-timestamp + POST + /api/shipping/providers/EASYPOST/webhooks + raw JSON body
POST {{baseUrl}}/api/shipping/providers/EASYPOST/webhooks
Content-Type: application/json
X-Timestamp: Sat, 04 Apr 2026 18:15:00 GMT
X-Path: /api/shipping/providers/EASYPOST/webhooks
X-Hmac-Signature-V2: hmac-sha256-hex=replace-with-real-signature

{
  "id": "evt_replace_me",
  "object": "Event",
  "description": "tracker.updated",
  "created_at": "2026-04-04T18:15:00.000Z",
  "result": {
    "id": "trk_replace_me",
    "object": "Tracker",
    "tracking_code": "EZREPLACEME123456",
    "status": "in_transit",
    "shipment_id": "shp_replace_me"
  }
}

### Request provider void/cancel for a shipment when supported (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/cancel
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Generate a replacement shipment after a prior shipment is fully voided (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/regenerate
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Prepare Windows local-agent print payload (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/prepare-print
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

{
  "printerId": "{{printerId}}",
  "copies": 1
}

### Print the shipment label through the configured Windows/local print agent (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/print
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

{
  "printerId": "{{printerId}}",
  "copies": 1
}

### Record the shipment label as printed manually (MANAGER+ fallback)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/record-printed
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}

### Mark the shipment as dispatched (MANAGER+)
POST {{baseUrl}}/api/online-store/shipments/{{shipmentId}}/dispatch
X-Staff-Role: {{managerRole}}
X-Staff-Id: {{managerId}}
