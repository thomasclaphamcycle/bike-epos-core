@baseUrl = http://localhost:3000
@staffRole = STAFF
@managerRole = MANAGER

### Product search by text query (STAFF+)
GET {{baseUrl}}/api/products/search?q=tube&take=20&skip=0
X-Staff-Role: {{staffRole}}
X-Staff-Id: demo-staff

### Product search by barcode (STAFF+)
GET {{baseUrl}}/api/products/search?barcode=1234567890123&take=20&skip=0
X-Staff-Role: {{staffRole}}
X-Staff-Id: demo-staff

### Create product with default sellable variant (MANAGER+)
POST {{baseUrl}}/api/products
Content-Type: application/json
X-Staff-Role: {{managerRole}}
X-Staff-Id: demo-manager

{
  "name": "Shimano Resin Pads B05S",
  "category": "Brakes",
  "isActive": true,
  "defaultVariant": {
    "sku": "SHIM-B05S",
    "manufacturerBarcode": "1234567890123",
    "retailPrice": "14.99",
    "isActive": true
  }
}
