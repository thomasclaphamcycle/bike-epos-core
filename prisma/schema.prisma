generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id        String   @id @default(cuid())
  name      String
  code      String?  @unique
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockBalances StockBalance[]
  stockMovesFrom StockMovement[] @relation("StockFrom")
  stockMovesTo   StockMovement[] @relation("StockTo")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  brand     String?
  description String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants Variant[]
  workshopLines WorkshopJobLine[]
}

model Supplier {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  RECEIVED_PARTIAL
  RECEIVED_COMPLETE
  CANCELLED
}

model PurchaseOrder {
  id         String              @id @default(uuid()) @db.Uuid
  supplierId String              @db.Uuid
  status     PurchaseOrderStatus @default(DRAFT)
  referenceCode String?          @unique
  currency   String              @default("GBP")
  subtotalPence Int              @default(0)
  taxPence   Int                 @default(0)
  totalPence Int                 @default(0)
  orderedAt  DateTime?
  expectedAt DateTime?
  notes      String?
  submittedAt DateTime?
  cancelledAt DateTime?
  createdByStaffId String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items      PurchaseOrderItem[]
  receipts   PurchaseReceipt[]
  createdByStaff User?           @relation("PurchaseOrderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([status, createdAt])
  @@index([createdByStaffId])
}

model PurchaseOrderItem {
  id               String   @id @default(uuid()) @db.Uuid
  purchaseOrderId  String   @db.Uuid
  variantId        String
  quantityOrdered  Int
  quantityReceived Int      @default(0)
  unitCostPence    Int?
  lineTotalPence   Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant          Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  receiptLines     PurchaseReceiptLine[]

  @@unique([purchaseOrderId, variantId])
  @@index([purchaseOrderId, createdAt])
  @@index([variantId])
}

model PurchaseReceipt {
  id               String   @id @default(uuid()) @db.Uuid
  purchaseOrderId  String   @db.Uuid
  receivedAt       DateTime @default(now())
  receivedByStaffId String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedByStaff  User?         @relation("PurchaseReceiptReceivedByStaff", fields: [receivedByStaffId], references: [id], onDelete: SetNull)
  lines            PurchaseReceiptLine[]

  @@index([purchaseOrderId, receivedAt])
  @@index([receivedByStaffId])
}

model PurchaseReceiptLine {
  id                String   @id @default(uuid()) @db.Uuid
  receiptId         String   @db.Uuid
  purchaseOrderLineId String @db.Uuid
  quantityReceived  Int
  unitCostPence     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  receipt           PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderItem @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)

  @@unique([receiptId, purchaseOrderLineId])
  @@index([purchaseOrderLineId])
}

model Variant {
  id        String   @id @default(cuid())
  productId String
  sku       String   @unique
  barcode   String?  @unique
  name      String?
  option    String?
  retailPrice      Decimal @default(0) @db.Decimal(12, 2)
  retailPricePence Int @default(0)
  costPricePence  Int?
  taxCode   String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id])
  barcodes  Barcode[]
  balances  StockBalance[]
  movements StockMovement[]
  basketItems BasketItem[]
  saleItems SaleItem[]
  inventoryMovements InventoryMovement[]
  stockLedgerEntries StockLedgerEntry[]
  workshopParts WorkshopJobPart[]
  purchaseOrderItems PurchaseOrderItem[]
  stocktakeLines     StocktakeLine[]
  workshopLines      WorkshopJobLine[]
}

model Barcode {
  id        String  @id @default(cuid())
  variantId String
  code      String  @unique
  type      BarcodeType @default(EAN)
  isPrimary Boolean @default(false)
  packQty   Int     @default(1)

  createdAt DateTime @default(now())

  variant   Variant @relation(fields: [variantId], references: [id])
}

enum BarcodeType {
  EAN
  INTERNAL
}

model StockBalance {
  id         String @id @default(cuid())
  variantId  String
  locationId String
  onHand     Int    @default(0)

  updatedAt  DateTime @updatedAt

  variant   Variant  @relation(fields: [variantId], references: [id])
  location  Location @relation(fields: [locationId], references: [id])

  @@unique([variantId, locationId])
}

model StockMovement {
  id             String @id @default(cuid())
  variantId      String
  qty            Int
  fromLocationId String?
  toLocationId   String?
  reason         StockMoveReason
  notes          String?
  createdAt      DateTime @default(now())

  variant       Variant   @relation(fields: [variantId], references: [id])
  fromLocation  Location? @relation("StockFrom", fields: [fromLocationId], references: [id])
  toLocation    Location? @relation("StockTo", fields: [toLocationId], references: [id])
}

enum StockMoveReason {
  PURCHASE_RECEIPT
  SALE
  RETURN
  TRANSFER
  ADJUSTMENT
  STOCK_TAKE
  WORKSHOP_ALLOCATE
  WORKSHOP_CONSUME
}

model StockLocation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stockLedgerEntries StockLedgerEntry[]
  stocktakes         Stocktake[]

  @@index([name])
}

enum StockLedgerEntryType {
  ADJUSTMENT
  SALE
  WORKSHOP
  PURCHASE
  RETURN
  TRANSFER
}

model StockLedgerEntry {
  id               String              @id @default(uuid()) @db.Uuid
  variantId        String
  locationId       String              @db.Uuid
  type             StockLedgerEntryType
  quantityDelta    Int
  unitCostPence    Int?
  referenceType    String
  referenceId      String
  note             String?
  createdAt        DateTime            @default(now())
  createdByStaffId String?

  variant          Variant             @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location         StockLocation       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdByStaff   User?               @relation("StockLedgerEntryCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([variantId, locationId, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdByStaffId])
}

enum StocktakeStatus {
  OPEN
  POSTED
  CANCELLED
}

model Stocktake {
  id         String          @id @default(uuid()) @db.Uuid
  locationId String          @db.Uuid
  status     StocktakeStatus @default(OPEN)
  startedAt  DateTime        @default(now())
  postedAt   DateTime?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  location   StockLocation   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  lines      StocktakeLine[]

  @@index([locationId, status])
}

model StocktakeLine {
  id         String    @id @default(uuid()) @db.Uuid
  stocktakeId String   @db.Uuid
  variantId  String
  countedQty Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  stocktake  Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  variant    Variant   @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([stocktakeId, variantId])
}

enum BasketStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

model Basket {
  id        String       @id @default(uuid()) @db.Uuid
  status    BasketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items     BasketItem[]
  sale      Sale?
}

model BasketItem {
  id         String   @id @default(uuid()) @db.Uuid
  basketId   String   @db.Uuid
  variantId  String
  quantity   Int
  unitPrice  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  basket     Basket  @relation(fields: [basketId], references: [id], onDelete: Cascade)
  variant    Variant @relation(fields: [variantId], references: [id])

  @@unique([basketId, variantId])
}

enum PaymentMethod {
  CASH
  CARD
  OTHER
}

enum SaleTenderMethod {
  CASH
  CARD
  BANK_TRANSFER
  VOUCHER
}

enum RefundRecordStatus {
  DRAFT
  COMPLETED
  VOID
}

enum RefundTenderType {
  CASH
  CARD
  VOUCHER
  OTHER
}

enum PaymentPurpose {
  DEPOSIT
  FINAL
  ADJUSTMENT
  CREDIT_APPLIED
  CREDIT_ISSUED
}

enum PaymentStatus {
  COMPLETED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentIntentStatus {
  REQUIRES_ACTION
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELED
}

model Sale {
  id            String   @id @default(uuid()) @db.Uuid
  basketId      String?  @unique @db.Uuid
  workshopJobId String?  @unique @db.Uuid
  customerId    String?  @db.Uuid
  subtotalPence Int
  taxPence      Int
  totalPence    Int
  changeDuePence Int @default(0)
  createdAt     DateTime @default(now())
  completedAt   DateTime?
  receiptNumber String?  @unique
  createdByStaffId String?

  basket        Basket?  @relation(fields: [basketId], references: [id], onDelete: SetNull)
  workshopJob   WorkshopJob? @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdByStaff User?   @relation("SaleCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  items         SaleItem[]
  payments      Payment[]
  tenders       SaleTender[]
  receipt       Receipt?
  paymentIntents PaymentIntent[]
  returns       SaleReturn[]
  refunds       Refund[]
  cashMovements CashMovement[] @relation("CashMovementSale")

  @@index([customerId])
  @@index([workshopJobId])
  @@index([completedAt])
  @@index([createdByStaffId])
}

model SaleItem {
  id             String   @id @default(uuid()) @db.Uuid
  saleId         String   @db.Uuid
  variantId      String
  quantity       Int
  unitPricePence Int
  lineTotalPence Int

  sale           Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant        Variant @relation(fields: [variantId], references: [id])
  returnItems    SaleReturnItem[]
  refundLines    RefundLine[]
}

model SaleTender {
  id               String           @id @default(uuid()) @db.Uuid
  saleId           String           @db.Uuid
  method           SaleTenderMethod
  amountPence      Int
  createdAt        DateTime         @default(now())
  createdByStaffId String?

  sale             Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdByStaff   User?            @relation("SaleTenderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([saleId, createdAt])
  @@index([createdByStaffId])
}

model ReceiptSettings {
  id          Int      @id @default(1)
  shopName    String   @default("Bike EPOS")
  shopAddress String   @default("123 Service Lane")
  vatNumber   String?
  footerText  String?  @default("Thank you for your custom.")
  updatedAt   DateTime @updatedAt
}

model ReceiptCounter {
  id        Int      @id @default(1)
  nextValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Receipt {
  id              String   @id @default(uuid()) @db.Uuid
  saleId          String?  @unique @db.Uuid
  refundId        String?  @unique @db.Uuid
  saleRefundId    String?  @unique @db.Uuid
  receiptNumber   String   @unique
  issuedAt        DateTime @default(now())
  issuedByStaffId String?
  shopName        String
  shopAddress     String
  vatNumber       String?
  footerText      String?

  sale            Sale?        @relation(fields: [saleId], references: [id], onDelete: SetNull)
  refund          PaymentRefund? @relation(fields: [refundId], references: [id], onDelete: SetNull)
  saleRefund      Refund?      @relation("SaleRefundReceipt", fields: [saleRefundId], references: [id], onDelete: SetNull)
  issuedByStaff   User?        @relation("ReceiptIssuedByStaff", fields: [issuedByStaffId], references: [id], onDelete: SetNull)

  @@index([issuedAt])
  @@index([issuedByStaffId])
}

model Refund {
  id               String            @id @default(uuid()) @db.Uuid
  saleId           String            @db.Uuid
  status           RefundRecordStatus @default(DRAFT)
  currency         String            @default("GBP")
  subtotalPence    Int               @default(0)
  taxPence         Int               @default(0)
  totalPence       Int               @default(0)
  createdByStaffId String?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  sale             Sale              @relation(fields: [saleId], references: [id], onDelete: Restrict)
  createdByStaff   User?             @relation("RefundCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  lines            RefundLine[]
  tenders          RefundTender[]
  receipt          Receipt?          @relation("SaleRefundReceipt")
  cashMovements    CashMovement[]    @relation("CashMovementRefund")

  @@index([saleId, createdAt])
  @@index([status, createdAt])
  @@index([createdByStaffId])
}

model RefundLine {
  id             String   @id @default(uuid()) @db.Uuid
  refundId       String   @db.Uuid
  saleLineId     String   @db.Uuid
  quantity       Int
  unitPricePence Int
  lineTotalPence Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refund         Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  saleLine       SaleItem @relation(fields: [saleLineId], references: [id], onDelete: Restrict)

  @@unique([refundId, saleLineId])
  @@index([saleLineId])
}

model RefundTender {
  id               String           @id @default(uuid()) @db.Uuid
  refundId         String           @db.Uuid
  tenderType       RefundTenderType
  amountPence      Int
  meta             Json?
  createdAt        DateTime         @default(now())
  createdByStaffId String?

  refund           Refund           @relation(fields: [refundId], references: [id], onDelete: Cascade)
  createdByStaff   User?            @relation("RefundTenderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([refundId, createdAt])
  @@index([createdByStaffId])
}

model Payment {
  id                String         @id @default(uuid()) @db.Uuid
  saleId            String?        @db.Uuid
  workshopJobId     String?        @db.Uuid
  method            PaymentMethod
  purpose           PaymentPurpose @default(FINAL)
  status            PaymentStatus  @default(COMPLETED)
  amountPence       Int
  refundedTotalPence Int           @default(0)
  providerRef       String?
  createdAt         DateTime       @default(now())

  sale              Sale?          @relation(fields: [saleId], references: [id], onDelete: SetNull)
  workshopJob       WorkshopJob?   @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)
  refunds           PaymentRefund[]
  creditEntries     CreditLedgerEntry[]

  @@index([workshopJobId])
  @@index([purpose, createdAt])
}

model PaymentIntent {
  id          String              @id @default(uuid()) @db.Uuid
  provider    String
  status      PaymentIntentStatus @default(REQUIRES_ACTION)
  amountPence Int
  saleId      String              @db.Uuid
  externalRef String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  sale        Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId, createdAt])
  @@index([provider, status, createdAt])
}

enum RefundStatus {
  RECORDED
  PROCESSOR_PENDING
  PROCESSOR_SUCCEEDED
  PROCESSOR_FAILED
}

model PaymentRefund {
  id                String       @id @default(uuid()) @db.Uuid
  paymentId         String       @db.Uuid
  amountPence       Int
  reason            String
  status            RefundStatus @default(RECORDED)
  processorRefundId String?
  idempotencyKey    String?
  createdAt         DateTime     @default(now())

  payment           Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  cancellations     WorkshopCancellation[]
  receipt           Receipt?

  @@index([paymentId, createdAt])
  @@unique([paymentId, idempotencyKey])
}

enum InventoryMovementType {
  PURCHASE_RECEIPT
  PURCHASE
  SALE
  ADJUSTMENT
  WORKSHOP_USE
  RETURN
}

model InventoryMovement {
  id               String                @id @default(cuid())
  variantId        String
  type             InventoryMovementType
  quantity         Int
  unitCost         Decimal?              @db.Decimal(14, 4)
  referenceType    String?
  referenceId      String?
  note             String?
  createdByStaffId String?
  createdAt        DateTime              @default(now())

  variant          Variant               @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([variantId])
  @@index([type])
  @@index([createdAt])
}

model SaleReturn {
  id        String   @id @default(uuid()) @db.Uuid
  saleId    String   @db.Uuid
  createdAt DateTime @default(now())

  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Restrict)
  items     SaleReturnItem[]
}

model SaleReturnItem {
  id             String     @id @default(uuid()) @db.Uuid
  returnId       String     @db.Uuid
  saleItemId     String     @db.Uuid
  quantity       Int
  unitPricePence Int
  lineTotalPence Int
  createdAt      DateTime   @default(now())

  saleReturn     SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem       SaleItem   @relation(fields: [saleItemId], references: [id], onDelete: Restrict)

  @@index([saleItemId])
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @default("")
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
  workshopJobs WorkshopJob[]
  creditAccounts CreditAccount[]

  @@index([name])
  @@index([phone])
}

enum WorkshopJobStatus {
  BOOKING_MADE
  BIKE_ARRIVED
  WAITING_FOR_APPROVAL
  APPROVED
  WAITING_FOR_PARTS
  ON_HOLD
  BIKE_READY
  COMPLETED
  CANCELLED
}

enum WorkshopJobSource {
  ONLINE
  IN_STORE
}

enum WorkshopDepositStatus {
  NOT_REQUIRED
  REQUIRED
  PAID
}

enum CancellationOutcome {
  REFUND_DEPOSIT
  FORFEIT_DEPOSIT
  CONVERT_TO_CREDIT
  NO_DEPOSIT
}

model WorkshopJob {
  id            String            @id @default(uuid()) @db.Uuid
  customerId    String?           @db.Uuid
  customerName  String?
  bikeDescription String?
  assignedStaffId String?
  assignedStaffName String?
  status        WorkshopJobStatus @default(BOOKING_MADE)
  scheduledDate DateTime?
  source        WorkshopJobSource @default(IN_STORE)
  depositRequiredPence Int        @default(0)
  depositStatus WorkshopDepositStatus @default(NOT_REQUIRED)
  manageToken   String?           @unique
  manageTokenExpiresAt DateTime?
  cancelledAt   DateTime?
  completedAt   DateTime?
  closedAt      DateTime?
  finalizedBasketId String?       @db.Uuid
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer      Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedStaff User?             @relation("WorkshopJobAssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  sale          Sale?
  payments      Payment[]
  cancellations WorkshopCancellation[]
  jobNotes      WorkshopJobNote[]
  parts         WorkshopJobPart[]
  lines         WorkshopJobLine[]

  @@index([scheduledDate])
  @@index([status])
  @@index([status, completedAt])
  @@index([assignedStaffId])
  @@index([finalizedBasketId])
}

enum WorkshopJobPartStatus {
  PLANNED
  USED
  RETURNED
}

model WorkshopJobPart {
  id               String                @id @default(uuid()) @db.Uuid
  workshopJobId    String                @db.Uuid
  variantId        String
  quantity         Int
  unitPriceAtTime  Int
  costPriceAtTime  Int?
  status           WorkshopJobPartStatus @default(PLANNED)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  workshopJob      WorkshopJob           @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  variant          Variant               @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([workshopJobId, createdAt])
  @@index([variantId])
}

enum WorkshopJobLineType {
  PART
  LABOUR
}

model WorkshopJobLine {
  id            String              @id @default(uuid()) @db.Uuid
  jobId         String              @db.Uuid
  type          WorkshopJobLineType
  productId     String?
  variantId     String?
  description   String
  qty           Int
  unitPricePence Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  job           WorkshopJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  product       Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       Variant?            @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([type])
  @@index([productId])
  @@index([variantId])
}

enum WorkshopJobNoteVisibility {
  INTERNAL
  CUSTOMER
}

model WorkshopJobNote {
  id            String                    @id @default(uuid()) @db.Uuid
  workshopJobId String                    @db.Uuid
  authorStaffId String?
  visibility    WorkshopJobNoteVisibility @default(INTERNAL)
  note          String
  createdAt     DateTime                  @default(now())

  workshopJob   WorkshopJob               @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  authorStaff   User?                     @relation("WorkshopJobNoteAuthor", fields: [authorStaffId], references: [id], onDelete: SetNull)

  @@index([workshopJobId, createdAt])
  @@index([authorStaffId])
}

model CreditAccount {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String?  @db.Uuid
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  entries     CreditLedgerEntry[]
  cancellations WorkshopCancellation[]

  @@unique([customerId])
  @@unique([email, phone])
  @@index([email])
  @@index([phone])
}

model CreditLedgerEntry {
  id             String   @id @default(uuid()) @db.Uuid
  creditAccountId String  @db.Uuid
  paymentId      String?  @db.Uuid
  amountPence    Int
  sourceType     String
  sourceRef      String
  idempotencyKey String?
  notes          String?
  createdAt      DateTime @default(now())

  creditAccount  CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  cancellations  WorkshopCancellation[]

  @@index([creditAccountId, createdAt])
  @@index([sourceType, sourceRef])
  @@unique([creditAccountId, idempotencyKey])
  @@unique([creditAccountId, sourceType, sourceRef, amountPence])
}

model WorkshopCancellation {
  id                String              @id @default(uuid()) @db.Uuid
  workshopJobId     String              @unique @db.Uuid
  outcome           CancellationOutcome
  notes             String?
  paymentRefundId   String?             @db.Uuid
  creditAccountId   String?             @db.Uuid
  creditLedgerEntryId String?           @db.Uuid
  cancelledAt       DateTime            @default(now())
  createdAt         DateTime            @default(now())

  workshopJob       WorkshopJob         @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  paymentRefund     PaymentRefund?      @relation(fields: [paymentRefundId], references: [id], onDelete: SetNull)
  creditAccount     CreditAccount?      @relation(fields: [creditAccountId], references: [id], onDelete: SetNull)
  creditLedgerEntry CreditLedgerEntry?  @relation(fields: [creditLedgerEntryId], references: [id], onDelete: SetNull)

  @@index([cancelledAt])
  @@index([outcome, cancelledAt])
}

model BookingSettings {
  id              Int      @id @default(1)
  minBookableDate DateTime
  maxBookingsPerDay Int
  defaultDepositPence Int @default(1000)
  updatedAt       DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String
  entityId   String
  actorRole  String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

enum UserRole {
  STAFF
  MANAGER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  name         String?
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)

  assignedWorkshopJobs WorkshopJob[]    @relation("WorkshopJobAssignedStaff")
  workshopJobNotes     WorkshopJobNote[] @relation("WorkshopJobNoteAuthor")
  stockLedgerEntries   StockLedgerEntry[] @relation("StockLedgerEntryCreatedByStaff")
  createdSales         Sale[] @relation("SaleCreatedByStaff")
  saleTenders          SaleTender[] @relation("SaleTenderCreatedByStaff")
  createdRefunds       Refund[] @relation("RefundCreatedByStaff")
  refundTenders        RefundTender[] @relation("RefundTenderCreatedByStaff")
  issuedReceipts       Receipt[] @relation("ReceiptIssuedByStaff")
  openedCashSessions   CashSession[] @relation("CashSessionOpenedBy")
  closedCashSessions   CashSession[] @relation("CashSessionClosedBy")
  cashMovements        CashMovement[] @relation("CashMovementCreatedBy")
  cashCounts           CashCount[] @relation("CashCountCountedBy")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedByStaff")
  receivedPurchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptReceivedByStaff")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("app_user")
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  FLOAT_IN
  PAID_IN
  PAID_OUT
  CASH_SALE
  CASH_REFUND
}

model CashSession {
  id               String            @id @default(uuid()) @db.Uuid
  businessDate     DateTime
  openedAt         DateTime          @default(now())
  closedAt         DateTime?
  openedByStaffId  String?
  closedByStaffId  String?
  openingFloatPence Int
  status           CashSessionStatus @default(OPEN)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  openedByStaff    User?             @relation("CashSessionOpenedBy", fields: [openedByStaffId], references: [id], onDelete: SetNull)
  closedByStaff    User?             @relation("CashSessionClosedBy", fields: [closedByStaffId], references: [id], onDelete: SetNull)
  movements        CashMovement[]
  cashCount        CashCount?

  @@index([businessDate, status])
  @@index([openedByStaffId])
  @@index([closedByStaffId])
}

model CashMovement {
  id               String           @id @default(uuid()) @db.Uuid
  sessionId        String           @db.Uuid
  locationId       String           @default("default")
  type             CashMovementType
  amountPence      Int
  ref              String
  note             String?
  relatedSaleId    String?          @db.Uuid
  relatedRefundId  String?          @db.Uuid
  createdAt        DateTime         @default(now())
  createdByStaffId String?

  session          CashSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  relatedSale      Sale?            @relation("CashMovementSale", fields: [relatedSaleId], references: [id], onDelete: SetNull)
  relatedRefund    Refund?          @relation("CashMovementRefund", fields: [relatedRefundId], references: [id], onDelete: SetNull)
  createdByStaff   User?            @relation("CashMovementCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([locationId, createdAt])
  @@index([type, createdAt])
  @@index([relatedSaleId])
  @@index([relatedRefundId])
  @@index([createdByStaffId])
  @@unique([sessionId, type, ref])
}

model CashCount {
  id               String      @id @default(uuid()) @db.Uuid
  sessionId        String      @unique @db.Uuid
  countedCashPence Int
  notes            String?
  countedAt        DateTime    @default(now())
  countedByStaffId String?

  session          CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  countedByStaff   User?       @relation("CashCountCountedBy", fields: [countedByStaffId], references: [id], onDelete: SetNull)

  @@index([countedAt])
  @@index([countedByStaffId])
}
