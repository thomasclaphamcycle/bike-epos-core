  updatedAt         DateTime                       @updatedAt

  conversation WorkshopConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorStaff  User?                @relation("WorkshopMessageAuthor", fields: [authorStaffId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([authorStaffId])
  @@index([direction, createdAt])
}

model WorkshopEstimateLine {
  id                String              @id @default(uuid()) @db.Uuid
  estimateId        String              @db.Uuid
  workshopJobLineId String?             @db.Uuid
  sortOrder         Int
  type              WorkshopJobLineType
  productId         String?
  variantId         String?
  description       String
  qty               Int
  unitPricePence    Int
  lineTotalPence    Int
  createdAt         DateTime            @default(now())

  estimate WorkshopEstimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product  Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  Variant?         @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([estimateId, sortOrder])
  @@index([workshopJobLineId])
}

model ReminderCandidate {
  id                String                  @id @default(uuid()) @db.Uuid
  customerId        String?                 @db.Uuid
  workshopJobId     String                  @unique @db.Uuid
  sourceEvent       String
  dueAt             DateTime
  status            ReminderCandidateStatus @default(PENDING)
  reviewedAt        DateTime?
  reviewedByStaffId String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  workshopJob WorkshopJob @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)

  @@index([customerId, status])
  @@index([status, dueAt])
  @@index([sourceEvent, createdAt])
  @@index([reviewedAt])
}

enum WorkshopJobPartStatus {
  PLANNED
  USED
  RETURNED
}

model WorkshopJobPart {
  id              String                @id @default(uuid()) @db.Uuid
  workshopJobId   String                @db.Uuid
  variantId       String
  stockLocationId String                @db.Uuid
  quantity        Int
  unitPriceAtTime Int
  costPriceAtTime Int?
  status          WorkshopJobPartStatus @default(PLANNED)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  workshopJob   WorkshopJob   @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  variant       Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  stockLocation StockLocation @relation(fields: [stockLocationId], references: [id], onDelete: Restrict)

  @@index([workshopJobId, createdAt])
  @@index([variantId])
  @@index([stockLocationId])
  @@index([variantId, stockLocationId, status])
}

enum WorkshopJobLineType {
  PART
  LABOUR
}

model WorkshopJobLine {
  id             String              @id @default(uuid()) @db.Uuid
  jobId          String              @db.Uuid
  type           WorkshopJobLineType
  productId      String?
  variantId      String?
  description    String
  qty            Int
  unitPricePence Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  job     WorkshopJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  product Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant Variant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([type])
  @@index([productId])
  @@index([variantId])
}

model WorkshopServiceTemplate {
  id                     String                     @id @default(uuid()) @db.Uuid
  name                   String
  description            String?
  category               String?
  sortOrder              Int                        @default(0)
  defaultDurationMinutes Int?
  pricingMode            WorkshopServicePricingMode @default(STANDARD_SERVICE)
  targetTotalPricePence  Int?
  isActive               Boolean                    @default(true)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  lines WorkshopServiceTemplateLine[]

  @@index([sortOrder, name])
  @@index([isActive, name])
  @@index([category, isActive])
}

model WorkshopServiceTemplateLine {
  id             String              @id @default(uuid()) @db.Uuid
  templateId     String              @db.Uuid
  type           WorkshopJobLineType
  productId      String?
  variantId      String?
  description    String
  qty            Int
  unitPricePence Int?
  isOptional     Boolean             @default(false)
  sortOrder      Int
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  template WorkshopServiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  product  Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  Variant?                @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([templateId, sortOrder])
  @@index([productId])
  @@index([variantId])
}

enum WorkshopJobNoteVisibility {
  INTERNAL
  CUSTOMER
}

model WorkshopJobNote {
  id            String                    @id @default(uuid()) @db.Uuid
  workshopJobId String                    @db.Uuid
  authorStaffId String?
  visibility    WorkshopJobNoteVisibility @default(INTERNAL)
  note          String
  createdAt     DateTime                  @default(now())

  workshopJob WorkshopJob @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  authorStaff User?       @relation("WorkshopJobNoteAuthor", fields: [authorStaffId], references: [id], onDelete: SetNull)

  @@index([workshopJobId, createdAt])
  @@index([authorStaffId])
}

model CreditAccount {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String?  @db.Uuid
  email      String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer      Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  entries       CreditLedgerEntry[]
  cancellations WorkshopCancellation[]

  @@unique([customerId])
  @@unique([email, phone])
  @@index([email])
  @@index([phone])
}

model CreditLedgerEntry {
  id              String   @id @default(uuid()) @db.Uuid
  creditAccountId String   @db.Uuid
  paymentId       String?  @db.Uuid
  amountPence     Int
  sourceType      String
  sourceRef       String
  idempotencyKey  String?
  notes           String?
  createdAt       DateTime @default(now())

  creditAccount CreditAccount          @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  payment       Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  cancellations WorkshopCancellation[]

  @@unique([creditAccountId, idempotencyKey])
  @@unique([creditAccountId, sourceType, sourceRef, amountPence])
  @@index([creditAccountId, createdAt])
  @@index([sourceType, sourceRef])
}

model WorkshopCancellation {
  id                  String              @id @default(uuid()) @db.Uuid
  workshopJobId       String              @unique @db.Uuid
  outcome             CancellationOutcome
  notes               String?
  paymentRefundId     String?             @db.Uuid
  creditAccountId     String?             @db.Uuid
  creditLedgerEntryId String?             @db.Uuid
  cancelledAt         DateTime            @default(now())
  createdAt           DateTime            @default(now())

  workshopJob       WorkshopJob        @relation(fields: [workshopJobId], references: [id], onDelete: Cascade)
  paymentRefund     PaymentRefund?     @relation(fields: [paymentRefundId], references: [id], onDelete: SetNull)
  creditAccount     CreditAccount?     @relation(fields: [creditAccountId], references: [id], onDelete: SetNull)
  creditLedgerEntry CreditLedgerEntry? @relation(fields: [creditLedgerEntryId], references: [id], onDelete: SetNull)

  @@index([cancelledAt])
  @@index([outcome, cancelledAt])
}

model BookingSettings {
  id                  Int      @id @default(1)
  minBookableDate     DateTime
  maxBookingsPerDay   Int
  defaultDepositPence Int      @default(1000)
  updatedAt           DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entityType String
  entityId   String
  actorRole  String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model DomainEvent {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String
  eventName     String
  entityType    String
  entityId      String
  customerId    String?  @db.Uuid
  bikeId        String?  @db.Uuid
  workshopJobId String?  @db.Uuid
  saleId        String?  @db.Uuid
  variantId     String?
  requestId     String?
  actorStaffId  String?
  payload       Json
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@index([eventName, occurredAt])
  @@index([entityType, entityId, occurredAt])
  @@index([customerId, occurredAt])
  @@index([bikeId, occurredAt])
  @@index([workshopJobId, occurredAt])
  @@index([saleId, occurredAt])
  @@index([variantId, occurredAt])
  @@index([actorStaffId, occurredAt])
  @@index([requestId])
}

enum UserRole {
  STAFF
  MANAGER
  ADMIN
}

enum UserOperationalRole {
  WORKSHOP
  SALES
  ADMIN
  MIXED
}

model User {
  id              String               @id @default(cuid())
  username        String               @unique
  email           String?              @unique
  name            String?
  passwordHash    String
  pinHash         String?
  role            UserRole             @default(STAFF)
  operationalRole UserOperationalRole?
  isTechnician    Boolean              @default(false)
  isActive        Boolean              @default(true)

  assignedWorkshopJobs     WorkshopJob[]          @relation("WorkshopJobAssignedStaff")
  workshopWorkingHours     WorkshopWorkingHours[] @relation("WorkshopWorkingHoursStaff")
  workshopTimeOff          WorkshopTimeOff[]      @relation("WorkshopTimeOffStaff")
  workshopJobNotes         WorkshopJobNote[]      @relation("WorkshopJobNoteAuthor")
  workshopMessages         WorkshopMessage[]      @relation("WorkshopMessageAuthor")
  workshopAttachments      WorkshopAttachment[]   @relation("WorkshopAttachmentUploadedByStaff")
  createdWorkshopEstimates WorkshopEstimate[]     @relation("WorkshopEstimateCreatedBy")
  decidedWorkshopEstimates WorkshopEstimate[]     @relation("WorkshopEstimateDecisionBy")
  stockLedgerEntries       StockLedgerEntry[]     @relation("StockLedgerEntryCreatedByStaff")
  createdSales             Sale[]                 @relation("SaleCreatedByStaff")
  saleTenders              SaleTender[]           @relation("SaleTenderCreatedByStaff")
  createdRefunds           Refund[]               @relation("RefundCreatedByStaff")
  refundTenders            RefundTender[]         @relation("RefundTenderCreatedByStaff")
  issuedReceipts           Receipt[]              @relation("ReceiptIssuedByStaff")
  openedCashSessions       CashSession[]          @relation("CashSessionOpenedBy")
  closedCashSessions       CashSession[]          @relation("CashSessionClosedBy")
  cashMovements            CashMovement[]         @relation("CashMovementCreatedBy")
  cashCounts               CashCount[]            @relation("CashCountCountedBy")
  createdWebOrders         WebOrder[]             @relation("WebOrderCreatedByStaff")
  packedWebOrders          WebOrder[]             @relation("WebOrderPackedByStaff")
  createdWebOrderShipments WebOrderShipment[]     @relation("WebOrderShipmentCreatedByStaff")
  createdStockTransfers    StockTransfer[]        @relation("StockTransferCreatedByStaff")
  sentStockTransfers       StockTransfer[]        @relation("StockTransferSentByStaff")
  receivedStockTransfers   StockTransfer[]        @relation("StockTransferReceivedByStaff")
  createdHireBookings      HireBooking[]          @relation("HireBookingCreatedByStaff")
  checkedOutHireBookings   HireBooking[]          @relation("HireBookingCheckedOutByStaff")
  returnedHireBookings     HireBooking[]          @relation("HireBookingReturnedByStaff")
  cancelledHireBookings    HireBooking[]          @relation("HireBookingCancelledByStaff")
  rotaAssignments          RotaAssignment[]
  holidayRequests          HolidayRequest[]       @relation("HolidayRequestStaff")
  reviewedHolidayRequests  HolidayRequest[]       @relation("HolidayRequestReviewedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_user")
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  FLOAT_IN
  PAID_IN
  PAID_OUT
  CASH_SALE
  CASH_REFUND
}

enum CashMovementReason {
  BANK_DEPOSIT
  SAFE_DROP
  SUPPLIER_PAYMENT
  PETTY_EXPENSE
  OTHER
}

model CashSession {
  id                String            @id @default(uuid()) @db.Uuid
  businessDate      DateTime
  openedAt          DateTime          @default(now())
  closedAt          DateTime?
  openedByStaffId   String?
  closedByStaffId   String?
  openingFloatPence Int
  status            CashSessionStatus @default(OPEN)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  openedByStaff User?          @relation("CashSessionOpenedBy", fields: [openedByStaffId], references: [id], onDelete: SetNull)
  closedByStaff User?          @relation("CashSessionClosedBy", fields: [closedByStaffId], references: [id], onDelete: SetNull)
  movements     CashMovement[]
  cashCount     CashCount?

  @@index([businessDate, status])
  @@index([openedByStaffId])
  @@index([closedByStaffId])
}

model CashMovement {
  id               String              @id @default(uuid()) @db.Uuid
  sessionId        String              @db.Uuid
  locationId       String              @default("default")
  type             CashMovementType
  reason           CashMovementReason?
  amountPence      Int
  ref              String
  note             String?
  receiptImageUrl  String?
  relatedSaleId    String?             @db.Uuid
  relatedRefundId  String?             @db.Uuid
  createdAt        DateTime            @default(now())
  createdByStaffId String?

  session             CashSession              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  relatedSale         Sale?                    @relation("CashMovementSale", fields: [relatedSaleId], references: [id], onDelete: SetNull)
  relatedRefund       Refund?                  @relation("CashMovementRefund", fields: [relatedRefundId], references: [id], onDelete: SetNull)
  createdByStaff      User?                    @relation("CashMovementCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  receiptUploadTokens CashReceiptUploadToken[]

  @@unique([sessionId, type, ref])
  @@index([sessionId, createdAt])
  @@index([locationId, createdAt])
  @@index([type, createdAt])
  @@index([relatedSaleId])
  @@index([relatedRefundId])
  @@index([createdByStaffId])
}

model CashReceiptUploadToken {
  id             String    @id @default(uuid()) @db.Uuid
  token          String    @unique
  cashMovementId String    @db.Uuid
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id], onDelete: Cascade)

  @@index([cashMovementId])
  @@index([expiresAt])
}

model CashCount {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String   @unique @db.Uuid
  countedCashPence Int
  notes            String?
  countedAt        DateTime @default(now())
  countedByStaffId String?

  session        CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  countedByStaff User?       @relation("CashCountCountedBy", fields: [countedByStaffId], references: [id], onDelete: SetNull)

  @@index([countedAt])
  @@index([countedByStaffId])
}
