generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id       String  @id @default(cuid())
  name     String
  code     String? @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockBalances  StockBalance[]
  stockMovesFrom StockMovement[] @relation("StockFrom")
  stockMovesTo   StockMovement[] @relation("StockTo")
  sales          Sale[]
  workshopJobs   WorkshopJob[]
}

model Product {
  id          String  @id @default(cuid())
  name        String
  brand       String?
  category    String?
  description String?
  keySellingPoints String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants      Variant[]
  workshopLines WorkshopJobLine[]
  estimateLines WorkshopEstimateLine[]
  templateLines WorkshopServiceTemplateLine[]
}

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  contactName String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  productLinks   SupplierProductLink[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id         String              @id @default(uuid()) @db.Uuid
  poNumber   String              @unique
  supplierId String              @db.Uuid
  status     PurchaseOrderStatus @default(DRAFT)
  orderedAt  DateTime?
  expectedAt DateTime?
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status, createdAt])
}

model PurchaseOrderItem {
  id               String   @id @default(uuid()) @db.Uuid
  purchaseOrderId  String   @db.Uuid
  variantId        String
  quantityOrdered  Int
  quantityReceived Int      @default(0)
  unitCostPence    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([purchaseOrderId, variantId])
  @@index([purchaseOrderId, createdAt])
  @@index([variantId])
}

model Variant {
  id                  String  @id @default(cuid())
  productId           String
  sku                 String  @unique
  barcode             String? @unique
  manufacturerBarcode String? @unique
  internalBarcode     String? @unique
  name                String?
  option              String?
  retailPrice         Decimal @default(0) @db.Decimal(12, 2)
  retailPricePence    Int     @default(0)
  costPricePence      Int?
  taxCode             String?
  isActive            Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product            Product                       @relation(fields: [productId], references: [id])
  barcodes           Barcode[]
  balances           StockBalance[]
  movements          StockMovement[]
  basketItems        BasketItem[]
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  stockLedgerEntries StockLedgerEntry[]
  workshopParts      WorkshopJobPart[]
  purchaseOrderItems PurchaseOrderItem[]
  supplierLinks      SupplierProductLink[]
  stocktakeLines     StocktakeLine[]
  workshopLines      WorkshopJobLine[]
  estimateLines      WorkshopEstimateLine[]
  stockTransferLines StockTransferLine[]
  hireAssets         HireAsset[]
  templateLines      WorkshopServiceTemplateLine[]
  webOrderItems      WebOrderItem[]
}

model SupplierProductLink {
  id                  String   @id @default(uuid()) @db.Uuid
  supplierId          String   @db.Uuid
  variantId           String
  supplierProductCode String?
  supplierCostPence   Int?
  preferredSupplier   Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variant  Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([supplierId, variantId])
  @@index([supplierId, isActive])
  @@index([variantId, isActive])
  @@index([variantId, preferredSupplier, isActive])
}

model Barcode {
  id        String      @id @default(cuid())
  variantId String
  code      String      @unique
  type      BarcodeType @default(EAN)
  isPrimary Boolean     @default(false)
  packQty   Int         @default(1)

  createdAt DateTime @default(now())

  variant Variant @relation(fields: [variantId], references: [id])
}

enum BarcodeType {
  EAN
  INTERNAL
}

model StockBalance {
  id         String @id @default(cuid())
  variantId  String
  locationId String
  onHand     Int    @default(0)

  updatedAt DateTime @updatedAt

  variant  Variant  @relation(fields: [variantId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([variantId, locationId])
}

model StockMovement {
  id             String          @id @default(cuid())
  variantId      String
  qty            Int
  fromLocationId String?
  toLocationId   String?
  reason         StockMoveReason
  notes          String?
  createdAt      DateTime        @default(now())

  variant      Variant   @relation(fields: [variantId], references: [id])
  fromLocation Location? @relation("StockFrom", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("StockTo", fields: [toLocationId], references: [id])
}

enum StockMoveReason {
  PURCHASE_RECEIPT
  SALE
  RETURN
  TRANSFER
  ADJUSTMENT
  STOCK_TAKE
  WORKSHOP_ALLOCATE
  WORKSHOP_CONSUME
}

model StockLocation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stockLedgerEntries StockLedgerEntry[]
  stocktakes         Stocktake[]
  workshopParts      WorkshopJobPart[]
  inventoryMovements InventoryMovement[]
  transfersFrom      StockTransfer[]     @relation("StockTransferFromLocation")
  transfersTo        StockTransfer[]     @relation("StockTransferToLocation")

  @@index([name])
}

enum StockTransferStatus {
  DRAFT
  SENT
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id                String              @id @default(uuid()) @db.Uuid
  fromLocationId    String              @db.Uuid
  toLocationId      String              @db.Uuid
  status            StockTransferStatus @default(DRAFT)
  notes             String?
  createdByStaffId  String?
  sentByStaffId     String?
  receivedByStaffId String?
  sentAt            DateTime?
  receivedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  fromLocation    StockLocation       @relation("StockTransferFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation      StockLocation       @relation("StockTransferToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  createdByStaff  User?               @relation("StockTransferCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  sentByStaff     User?               @relation("StockTransferSentByStaff", fields: [sentByStaffId], references: [id], onDelete: SetNull)
  receivedByStaff User?               @relation("StockTransferReceivedByStaff", fields: [receivedByStaffId], references: [id], onDelete: SetNull)
  lines           StockTransferLine[]

  @@index([status, createdAt])
  @@index([fromLocationId, status])
  @@index([toLocationId, status])
}

model StockTransferLine {
  id              String   @id @default(uuid()) @db.Uuid
  stockTransferId String   @db.Uuid
  variantId       String
  quantity        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  variant       Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([stockTransferId, variantId])
  @@index([variantId])
}

enum HireAssetStatus {
  AVAILABLE
  RESERVED
  ON_HIRE
  MAINTENANCE
  RETIRED
}

enum HireBookingStatus {
  RESERVED
  CHECKED_OUT
  RETURNED
  CANCELLED
}

enum HireDepositStatus {
  NONE
  HELD
  RETURNED
  KEPT
}

model HireAsset {
  id               String          @id @default(uuid()) @db.Uuid
  variantId        String
  assetTag         String          @unique
  displayName      String?
  notes            String?
  storageLocation  String?
  isOnlineBookable Boolean         @default(false)
  status           HireAssetStatus @default(AVAILABLE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  variant  Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  bookings HireBooking[]

  @@index([variantId])
  @@index([status, createdAt])
}

model HireBooking {
  id                  String            @id @default(uuid()) @db.Uuid
  hireAssetId         String            @db.Uuid
  customerId          String            @db.Uuid
  status              HireBookingStatus @default(RESERVED)
  depositStatus       HireDepositStatus @default(NONE)
  startsAt            DateTime
  dueBackAt           DateTime
  checkedOutAt        DateTime?
  returnedAt          DateTime?
  cancelledAt         DateTime?
  hirePricePence      Int               @default(0)
  depositPence        Int               @default(0)
  depositHeldPence    Int               @default(0)
  notes               String?
  pickupNotes         String?
  returnNotes         String?
  cancellationReason  String?
  damageNotes         String?
  createdByStaffId    String?
  checkedOutByStaffId String?
  returnedByStaffId   String?
  cancelledByStaffId  String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  hireAsset         HireAsset @relation(fields: [hireAssetId], references: [id], onDelete: Restrict)
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdByStaff    User?     @relation("HireBookingCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  checkedOutByStaff User?     @relation("HireBookingCheckedOutByStaff", fields: [checkedOutByStaffId], references: [id], onDelete: SetNull)
  returnedByStaff   User?     @relation("HireBookingReturnedByStaff", fields: [returnedByStaffId], references: [id], onDelete: SetNull)
  cancelledByStaff  User?     @relation("HireBookingCancelledByStaff", fields: [cancelledByStaffId], references: [id], onDelete: SetNull)

  @@index([hireAssetId, status])
  @@index([customerId, status])
  @@index([status, dueBackAt])
  @@index([status, startsAt])
}

enum StockLedgerEntryType {
  ADJUSTMENT
  SALE
  WORKSHOP
  PURCHASE
  RETURN
  TRANSFER
}

model StockLedgerEntry {
  id               String               @id @default(uuid()) @db.Uuid
  variantId        String
  locationId       String               @db.Uuid
  type             StockLedgerEntryType
  quantityDelta    Int
  unitCostPence    Int?
  referenceType    String
  referenceId      String
  note             String?
  createdAt        DateTime             @default(now())
  createdByStaffId String?

  variant        Variant       @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location       StockLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdByStaff User?         @relation("StockLedgerEntryCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([variantId, locationId, createdAt])
  @@index([referenceType, referenceId])
  @@index([createdByStaffId])
}

enum StocktakeStatus {
  OPEN
  POSTED
  CANCELLED
}

model Stocktake {
  id                String          @id @default(uuid()) @db.Uuid
  locationId        String          @db.Uuid
  status            StocktakeStatus @default(OPEN)
  startedAt         DateTime        @default(now())
  reviewRequestedAt DateTime?
  postedAt          DateTime?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  location StockLocation   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  lines    StocktakeLine[]

  @@index([locationId, status])
}

model StocktakeLine {
  id                  String   @id @default(uuid()) @db.Uuid
  stocktakeId         String   @db.Uuid
  variantId           String
  expectedQtySnapshot Int?
  countedQty          Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  stocktake Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  variant   Variant   @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([stocktakeId, variantId])
}

enum BasketStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

model Basket {
  id        String       @id @default(uuid()) @db.Uuid
  status    BasketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  items BasketItem[]
  sale  Sale?
}

model BasketItem {
  id        String   @id @default(uuid()) @db.Uuid
  basketId  String   @db.Uuid
  variantId String
  quantity  Int
  unitPrice Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  basket  Basket  @relation(fields: [basketId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([basketId, variantId])
}

enum PaymentMethod {
  CASH
  CARD
  OTHER
}

enum SaleTenderMethod {
  CASH
  CARD
  BANK_TRANSFER
  VOUCHER
}

enum RotaPeriodStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RotaShiftType {
  FULL_DAY
  HALF_DAY_AM
  HALF_DAY_PM
  HOLIDAY
}

enum RotaAssignmentSource {
  MANUAL
  IMPORT
  HOLIDAY_APPROVED
}

enum RotaClosedDayType {
  SCHEDULED_CLOSED
  BANK_HOLIDAY
  CUSTOM
}

enum HolidayRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RefundRecordStatus {
  DRAFT
  COMPLETED
  VOID
}

enum RefundTenderType {
  CASH
  CARD
  VOUCHER
  OTHER
}

enum PaymentPurpose {
  DEPOSIT
  FINAL
  ADJUSTMENT
  CREDIT_APPLIED
  CREDIT_ISSUED
}

enum PaymentStatus {
  COMPLETED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PaymentIntentStatus {
  REQUIRES_ACTION
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELED
}

enum SaleCustomerCaptureSessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum SaleCustomerCaptureMatchType {
  EMAIL
  PHONE
  CREATED
}

model Sale {
  id                 String    @id @default(uuid()) @db.Uuid
  basketId           String?   @unique @db.Uuid
  workshopJobId      String?   @unique @db.Uuid
  customerId         String?   @db.Uuid
  exchangeFromSaleId String?   @db.Uuid
  locationId         String
  subtotalPence      Int
  taxPence           Int
  totalPence         Int
  changeDuePence     Int       @default(0)
  createdAt          DateTime  @default(now())
  completedAt        DateTime?
  receiptNumber      String?   @unique
  createdByStaffId   String?

  basket                  Basket?                      @relation(fields: [basketId], references: [id], onDelete: SetNull)
  workshopJob             WorkshopJob?                 @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)
  customer                Customer?                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  exchangeFromSale        Sale?                        @relation("SaleExchangeSource", fields: [exchangeFromSaleId], references: [id], onDelete: SetNull)
  exchangeSales           Sale[]                       @relation("SaleExchangeSource")
  location                Location                     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdByStaff          User?                        @relation("SaleCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  items                   SaleItem[]
  payments                Payment[]
  tenders                 SaleTender[]
  receipt                 Receipt?
  paymentIntents          PaymentIntent[]
  returns                 SaleReturn[]
  refunds                 Refund[]
  customerCaptureSessions SaleCustomerCaptureSession[]
  cashMovements           CashMovement[]               @relation("CashMovementSale")
  workshopCheckoutOutcome WorkshopCheckoutOutcome?

  @@index([customerId])
  @@index([workshopJobId])
  @@index([exchangeFromSaleId])
  @@index([locationId])
  @@index([completedAt])
  @@index([createdByStaffId])
}

model SaleCustomerCaptureSession {
  id                    String                           @id @default(uuid()) @db.Uuid
  saleId                String                           @db.Uuid
  token                 String                           @unique
  status                SaleCustomerCaptureSessionStatus @default(ACTIVE)
  matchType             SaleCustomerCaptureMatchType?
  expiresAt             DateTime
  completedAt           DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  submittedFirstName    String?
  submittedLastName     String?
  submittedEmail        String?
  submittedPhone        String?
  emailMarketingConsent Boolean?
  smsMarketingConsent   Boolean?
  customerId            String?                          @db.Uuid

  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([saleId, status])
  @@index([expiresAt])
  @@index([customerId])
}

model SaleItem {
  id             String @id @default(uuid()) @db.Uuid
  saleId         String @db.Uuid
  variantId      String
  quantity       Int
  unitPricePence Int
  lineTotalPence Int

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant     Variant          @relation(fields: [variantId], references: [id])
  returnItems SaleReturnItem[]
  refundLines RefundLine[]
}

model SaleTender {
  id               String           @id @default(uuid()) @db.Uuid
  saleId           String           @db.Uuid
  method           SaleTenderMethod
  amountPence      Int
  createdAt        DateTime         @default(now())
  createdByStaffId String?

  sale           Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdByStaff User? @relation("SaleTenderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([saleId, createdAt])
  @@index([createdByStaffId])
}

model ReceiptSettings {
  id          Int      @id @default(1)
  shopName    String   @default("Bike EPOS")
  shopAddress String   @default("123 Service Lane")
  vatNumber   String?
  footerText  String?  @default("Thank you for your custom.")
  updatedAt   DateTime @updatedAt
}

model ReceiptCounter {
  id        Int      @id @default(1)
  nextValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model AppConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RotaPeriod {
  id        String           @id @default(uuid()) @db.Uuid
  label     String
  startsOn  String
  endsOn    String
  status    RotaPeriodStatus @default(DRAFT)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  assignments RotaAssignment[]

  @@unique([startsOn, endsOn])
  @@index([status, startsOn])
}

model RotaAssignment {
  id             String               @id @default(uuid()) @db.Uuid
  rotaPeriodId   String               @db.Uuid
  staffId        String
  date           String
  shiftType      RotaShiftType
  source         RotaAssignmentSource @default(MANUAL)
  note           String?
  rawValue       String?
  importBatchKey String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  rotaPeriod RotaPeriod @relation(fields: [rotaPeriodId], references: [id], onDelete: Restrict)
  staff      User       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([date, shiftType])
  @@index([rotaPeriodId, date])
}

model RotaClosedDay {
  id        String            @id @default(uuid()) @db.Uuid
  date      String            @unique
  type      RotaClosedDayType @default(CUSTOM)
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([type, date])
}

model WorkshopWorkingHours {
  id        String   @id @default(uuid()) @db.Uuid
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff User @relation("WorkshopWorkingHoursStaff", fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([staffId, dayOfWeek])
}

model WorkshopTimeOff {
  id        String   @id @default(uuid()) @db.Uuid
  staffId   String?
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff User? @relation("WorkshopTimeOffStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([staffId, startAt])
  @@index([staffId, endAt])
  @@index([startAt, endAt])
}

model HolidayRequest {
  id               String               @id @default(uuid()) @db.Uuid
  staffId          String
  startDate        String
  endDate          String
  status           HolidayRequestStatus @default(PENDING)
  requestNotes     String?
  decisionNotes    String?
  submittedAt      DateTime             @default(now())
  reviewedAt       DateTime?
  reviewedByUserId String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  staff          User  @relation("HolidayRequestStaff", fields: [staffId], references: [id], onDelete: Cascade)
  reviewedByUser User? @relation("HolidayRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([staffId, status, startDate])
  @@index([status, startDate])
  @@index([reviewedByUserId])
}

model Receipt {
  id              String   @id @default(uuid()) @db.Uuid
  saleId          String?  @unique @db.Uuid
  refundId        String?  @unique @db.Uuid
  saleRefundId    String?  @unique @db.Uuid
  receiptNumber   String   @unique
  issuedAt        DateTime @default(now())
  issuedByStaffId String?
  shopName        String
  shopAddress     String
  vatNumber       String?
  footerText      String?

  sale          Sale?          @relation(fields: [saleId], references: [id], onDelete: SetNull)
  refund        PaymentRefund? @relation(fields: [refundId], references: [id], onDelete: SetNull)
  saleRefund    Refund?        @relation("SaleRefundReceipt", fields: [saleRefundId], references: [id], onDelete: SetNull)
  issuedByStaff User?          @relation("ReceiptIssuedByStaff", fields: [issuedByStaffId], references: [id], onDelete: SetNull)

  @@index([issuedAt])
  @@index([issuedByStaffId])
}

model Refund {
  id                String             @id @default(uuid()) @db.Uuid
  saleId            String             @db.Uuid
  status            RefundRecordStatus @default(DRAFT)
  currency          String             @default("GBP")
  subtotalPence     Int                @default(0)
  taxPence          Int                @default(0)
  totalPence        Int                @default(0)
  returnToStock     Boolean            @default(false)
  returnedToStockAt DateTime?
  createdByStaffId  String?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  sale           Sale           @relation(fields: [saleId], references: [id], onDelete: Restrict)
  createdByStaff User?          @relation("RefundCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  lines          RefundLine[]
  tenders        RefundTender[]
  receipt        Receipt?       @relation("SaleRefundReceipt")
  cashMovements  CashMovement[] @relation("CashMovementRefund")

  @@index([saleId, createdAt])
  @@index([status, createdAt])
  @@index([createdByStaffId])
}

model RefundLine {
  id             String   @id @default(uuid()) @db.Uuid
  refundId       String   @db.Uuid
  saleLineId     String   @db.Uuid
  quantity       Int
  unitPricePence Int
  lineTotalPence Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  refund   Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  saleLine SaleItem @relation(fields: [saleLineId], references: [id], onDelete: Restrict)

  @@unique([refundId, saleLineId])
  @@index([saleLineId])
}

model RefundTender {
  id               String           @id @default(uuid()) @db.Uuid
  refundId         String           @db.Uuid
  tenderType       RefundTenderType
  amountPence      Int
  meta             Json?
  createdAt        DateTime         @default(now())
  createdByStaffId String?

  refund         Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)
  createdByStaff User?  @relation("RefundTenderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)

